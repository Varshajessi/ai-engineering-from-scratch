        <mxCell id="E-cl75kj5G9YbpEQe-Dy-74" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;font style=&quot;font-size: 15px;&quot;&gt;fnm - Fast Node Manager&lt;/font&gt;" vertex="1">
