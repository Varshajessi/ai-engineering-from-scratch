        <mxCell id="E-cl75kj5G9YbpEQe-Dy-76" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;div data-bfc=&quot;&quot; class=&quot;&quot; data-ved=&quot;2ahUKEwiKvuy0memUAxWxS_EDHbqNBTgQi4wTeggIAAgBCAsQCg&quot; style=&quot;color: rgb(10, 10, 10); font-family: &amp;quot;Google Sans&amp;quot;, Arial, sans-serif; font-size: medium; text-align: start; background-color: rgb(255, 255, 255);&quot;&gt;&lt;div class=&quot;n6owBd awi2gc&quot; data-sfc-cp=&quot;&quot; data-sfc-root=&quot;c&quot; data-sfc-cb=&quot;&quot; data-hveid=&quot;CAAIAQgLEAs&quot; style=&quot;overflow-wrap: break-word; font-size: 16px; line-height: 24px; text-wrap: wrap; margin-block: 12px 16px; margin-inline: 0px;&quot;&gt;&lt;font dir=&quot;auto&quot; style=&quot;vertical-align: inherit;&quot;&gt;Fast Node Manager is a robust, cross-platform tool used by developers to easily install, switch, and manage multiple versions of &lt;/font&gt;&lt;span class=&quot;T286Pc&quot; data-sfc-cp=&quot;&quot; data-sfc-root=&quot;c&quot; data-sfc-cb=&quot;&quot; style=&quot;overflow-wrap: break-word;&quot;&gt;&lt;font dir=&quot;auto&quot; style=&quot;vertical-align: inherit;&quot;&gt;Node.js&lt;/font&gt;&lt;/span&gt;&lt;font dir=&quot;auto&quot; style=&quot;vertical-align: inherit;&quot;&gt; on their computers.&amp;nbsp;&lt;/font&gt;&lt;span class=&quot;Yjhzub&quot; data-sfc-root=&quot;c&quot; data-sfc-cb=&quot;&quot; style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18)); color: light-dark(rgb(10, 10, 10), rgb(229, 229, 229)); font-weight: bolder; font-size: 14px;&quot;&gt;&lt;font dir=&quot;auto&quot; style=&quot;vertical-align: inherit;&quot;&gt;&lt;font dir=&quot;auto&quot; style=&quot;vertical-align: inherit;&quot;&gt;Why use it:&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;font dir=&quot;auto&quot; style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18)); color: light-dark(rgb(10, 10, 10), rgb(229, 229, 229)); font-size: 14px; vertical-align: inherit;&quot;&gt;&lt;font dir=&quot;auto&quot; style=&quot;vertical-align: inherit;&quot;&gt; It allows projects that require different versions of Node.js to run without conflict. It is written in &lt;b&gt;Rust&lt;/b&gt;, making it significantly faster than older alternatives like NVM.&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="153" width="837" x="1225" y="-236" as="geometry" />
        </mxCell>
