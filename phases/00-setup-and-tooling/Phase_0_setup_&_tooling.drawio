          <mxGeometry height="34" width="57" x="264" y="924" as="geometry" />
        </mxCell>
        <mxCell id="NtaSptESLH8KFiJJyjg8-141" edge="1" parent="1" source="NtaSptESLH8KFiJJyjg8-138" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=15;" target="NtaSptESLH8KFiJJyjg8-140" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="NtaSptESLH8KFiJJyjg8-138" parent="1" style="whiteSpace=wrap;html=1;rounded=0;fontSize=15;" value="&lt;font&gt;&lt;b&gt;In Python&lt;/b&gt;,&lt;/font&gt;&lt;div&gt;&lt;font&gt;&lt;font style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;To create one in python -&amp;gt;&amp;gt; &lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;python -m venv .venv&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;&amp;nbsp;To activate that in python -&amp;gt;&amp;gt; source .venv/bin/activate&lt;/font&gt;&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="388" x="405" y="906" as="geometry" />
        </mxCell>
        <mxCell id="NtaSptESLH8KFiJJyjg8-140" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=0;fontSize=15;" value="&lt;font style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;code style=&quot;font-family: &amp;quot;SF Mono&amp;quot;, Monaco, Menlo, Courier, monospace; color: rgb(59, 59, 59); padding: 1px 3px; border-radius: 4px; border-color: rgb(59, 59, 59); border-style: none; border-width: 0px; border-image: none 100% / 1 / 0 stretch; white-space: pre-wrap; text-align: start;&quot;&gt;-m&lt;/code&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, sans-serif; text-align: start;&quot;&gt; tells Python to run a library module as a script: it locates the module on sys.path and executes its &lt;/span&gt;&lt;code style=&quot;font-family: &amp;quot;SF Mono&amp;quot;, Monaco, Menlo, Courier, monospace; color: rgb(59, 59, 59); padding: 1px 3px; border-radius: 4px; border-color: rgb(59, 59, 59); border-style: none; border-width: 0px; border-image: none 100% / 1 / 0 stretch; white-space: pre-wrap; text-align: start;&quot;&gt;__main__&lt;/code&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, sans-serif; text-align: start;&quot;&gt; (as if you ran the module file).&lt;/span&gt;&lt;br style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, sans-serif; text-align: start;&quot;&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, sans-serif; text-align: start;&quot;&gt;So &lt;/span&gt;&lt;code style=&quot;font-family: &amp;quot;SF Mono&amp;quot;, Monaco, Menlo, Courier, monospace; color: rgb(59, 59, 59); padding: 1px 3px; border-radius: 4px; border-color: rgb(59, 59, 59); border-style: none; border-width: 0px; border-image: none 100% / 1 / 0 stretch; white-space: pre-wrap; text-align: start;&quot;&gt;python -m venv .venv&lt;/code&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, sans-serif; text-align: start;&quot;&gt; runs the standard-library &lt;/span&gt;&lt;code style=&quot;font-family: &amp;quot;SF Mono&amp;quot;, Monaco, Menlo, Courier, monospace; color: rgb(59, 59, 59); padding: 1px 3px; border-radius: 4px; border-color: rgb(59, 59, 59); border-style: none; border-width: 0px; border-image: none 100% / 1 / 0 stretch; white-space: pre-wrap; text-align: start;&quot;&gt;venv&lt;/code&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, sans-serif; text-align: start;&quot;&gt; module to create the environment.&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, sans-serif; text-align: start;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;span style=&quot;color: rgb(59, 59, 59); font-family: -apple-system, &amp;quot;system-ui&amp;quot;, sans-serif; text-align: start;&quot;&gt;And .venv is the folder name&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="134" width="689" x="870" y="862" as="geometry" />
        </mxCell>
        <mxCell id="NtaSptESLH8KFiJJyjg8-145" edge="1" parent="1" source="NtaSptESLH8KFiJJyjg8-142" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=15;" target="NtaSptESLH8KFiJJyjg8-144" value="">
