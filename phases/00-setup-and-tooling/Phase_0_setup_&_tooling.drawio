        </mxCell>
        <mxCell id="NtaSptESLH8KFiJJyjg8-236" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;labelBackgroundColor=default;rounded=0;fontSize=15;" value="&lt;font&gt;Version control systems like git track every change made to files, allowing you to revert to previous states and collaborate with others on the same codebase&lt;/font&gt;" vertex="1">
          <mxGeometry height="81" width="641" x="714" y="1715" as="geometry" />
        </mxCell>
        <mxCell id="E-cl75kj5G9YbpEQe-Dy-1" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=0;fontSize=15;" value="&lt;font style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;A repository (repo) is a directory tracked by git that contains all project files along with the full history of changes made to those files.&lt;/font&gt;" vertex="1">
          <mxGeometry height="72" width="555" x="738" y="1818.5" as="geometry" />
        </mxCell>
        <mxCell id="E-cl75kj5G9YbpEQe-Dy-2" edge="1" parent="1" source="NtaSptESLH8KFiJJyjg8-233" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.005;entryY=0.511;entryDx=0;entryDy=0;entryPerimeter=0;fontSize=15;" target="E-cl75kj5G9YbpEQe-Dy-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="E-cl75kj5G9YbpEQe-Dy-5" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;rounded=0;fontSize=15;" value="&lt;div&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;font color=&quot;#1f1f1f&quot; face=&quot;Google Sans, Arial, sans-serif&quot;&gt;The purpose of gitignore files is to ensure that certain files not tracked by Git remain untracked. To stop tracking a file that is currently tracked, use git rm --cached to remove the file from the index. The filename can then be added to the .gitignore file to stop the file from being reintroduced in later commits.&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="107" width="588" x="758" y="1952" as="geometry" />
        </mxCell>
        <mxCell id="E-cl75kj5G9YbpEQe-Dy-10" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;labelBorderColor=default;labelBackgroundColor=default;align=center;" value="&lt;h3 id=&quot;step-3-branching-for-experiments&quot; style=&quot;margin: 36px 0px 12px; padding: 0px; box-sizing: border-box; font-family: &amp;quot;JetBrains Mono&amp;quot;, ui-monospace, Consolas, monospace; line-height: 1; letter-spacing: 0.12em; text-transform: uppercase; color: rgb(26, 26, 26); font-size: 0.95rem; scroll-margin-top: 92px;&quot;&gt;Branching for experiments&lt;/h3&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;# to create new branch,&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;git checkout -b branch_name&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;# ... make changes, commit ...(to merge the branch)&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;git checkout main&lt;/div&gt;&lt;div style=&quot;font-size: 15px;&quot;&gt;git merge branch_name&lt;/div&gt;" vertex="1">
